---
interface Props {
  videoUrl: string;
  thumbnailUrl?: string;
  title?: string;
  startTime?: number;
  endTime?: number;
  isExtracted?: boolean;
}

const { videoUrl, thumbnailUrl, title, startTime, endTime, isExtracted } = Astro.props;
const isMP4 = isExtracted || (videoUrl && videoUrl.endsWith('.mp4'));
const playerId = `video-player-${Math.random().toString(36).slice(2, 9)}`;
---

{!isMP4 && <link href="https://vjs.zencdn.net/8.6.1/video-js.css" rel="stylesheet" />}

<div class="video-container">
  {isMP4 ? (
    <video
      id={playerId}
      controls
      preload="auto"
      width="800"
      height="450"
      poster={thumbnailUrl}
      data-start-time={startTime !== undefined ? startTime : undefined}
      data-end-time={endTime !== undefined ? endTime : undefined}
    >
      <source src={videoUrl} type="video/mp4" />
    </video>
  ) : (
    <video
      id={playerId}
      class="video-js vjs-default-skin"
      controls
      preload="auto"
      width="800"
      height="450"
      poster={thumbnailUrl}
      data-setup="{}"
      data-start-time={startTime}
      data-end-time={endTime}
    >
      <source src={videoUrl} type="application/x-mpegURL" />
      <p class="vjs-no-js">
        To view this video please enable JavaScript, and consider upgrading to a
        <a href="https://videojs.com/html5-video-support/" target="_blank">web browser that
        <span class="vjs-no-js-link">supports HTML5 video</span></a>.
      </p>
    </video>
  )}
  {title && <p class="video-title">{title}</p>}
</div>

<style>
  .video-js {
    display: block;
    margin-inline: auto;
    width: 100%;
    max-width: 800px;
    aspect-ratio: 16/9;
  }

  .video-container {
    max-width: 100%;
    margin: var(--spacing-lg) 0;
    background: var(--color-bg-soft);
    border-radius: var(--button-radius);
    padding: var(--spacing-md);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    border-left: 4px solid var(--color-primary);
  }

  video {
    width: 100%;
    height: auto;
    border-radius: var(--border-radius);
    box-shadow: 0 2px 15px rgba(0, 0, 0, 0.15);
    display: block;
    margin: 0 auto;
  }

  .video-title {
    margin-top: var(--spacing-md);
    font-size: 0.95rem;
    color: var(--color-text-light);
    text-align: center;
    font-style: italic;
    font-family: var(--font-heading);
  }
</style>

<script>
  // Initialize clip boundaries for all video players on this page.
  // HLS (video.video-js) uses Video.js; MP4 uses native HTML5 with inline JS.

  // ── HLS players ──────────────────────────────────────────────────────────
  const hlsVideos = document.querySelectorAll<HTMLVideoElement>('video.video-js');
  if (hlsVideos.length > 0) {
    import('@/utils/videojs-player').then(({ initializeVideoJsPlayer }) => {
      hlsVideos.forEach(async (el) => {
        const startTime = parseFloat(el.dataset.startTime || '');
        const endTime = parseFloat(el.dataset.endTime || '');
        try {
          await initializeVideoJsPlayer({
            playerId: el.id,
            startTime: isNaN(startTime) ? undefined : startTime,
            endTime: isNaN(endTime) ? undefined : endTime,
          });
        } catch (e) {
          console.error('Video.js init failed for', el.id, e);
        }
      });
    });
  }

  // ── MP4 players with clip boundaries ─────────────────────────────────────
  const mp4Videos = document.querySelectorAll<HTMLVideoElement>('video[data-start-time]:not(.video-js)');
  mp4Videos.forEach((video) => {
    const startTime = parseFloat(video.dataset.startTime || '');
    const endTime = parseFloat(video.dataset.endTime || '');
    if (isNaN(startTime) || isNaN(endTime)) return;

    // Seek to clip start when ready
    const seekToStart = () => {
      if (video.currentTime < startTime) video.currentTime = startTime;
    };
    video.addEventListener('loadedmetadata', seekToStart);
    if (video.readyState >= 1) seekToStart();

    // Stop at clip end
    video.addEventListener('timeupdate', () => {
      if (video.currentTime >= endTime) {
        video.pause();
        video.currentTime = endTime;
      }
    });

    // Prevent seeking before start
    video.addEventListener('seeking', () => {
      if (video.currentTime < startTime) video.currentTime = startTime;
      if (video.currentTime > endTime) video.currentTime = endTime;
    });
  });
</script>
