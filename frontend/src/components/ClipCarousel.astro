  .thumbnail-button {
    position: relative;
    border: 2px solid transparent;
    border-radius: var(--border-radius);
    background: none;
    cursor: pointer;
    transition: var(--transition);
    flex-shrink: 0;
    width: 80px;
    height: 60px;
    overflow: hidden;
  }

  .thumbnail-button.active {
    border-color: var(--color-secondary);
    box-shadow: 0 0 0 2px rgba(131, 205, 192, 0.3);
  }

  .thumbnail-button img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumbnail-overlay {
    position: absolute;
    top: 2px;
    left: 2px;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    font-size: 0.7rem;
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 600;
  }

  /* Metadata Drawer - overlays the sidebar */
  .metadata-drawer {
    position: fixed;
    left: 0;
    bottom: 0;
    width: 20%;
    z-index: 200;
    background: rgba(81, 81, 81, 0.95);
    backdrop-filter: blur(8px);
    border-top-right-radius: var(--border-radius);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.3);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 70vh;
    overflow: hidden;
  }

  .metadata-drawer[data-visible="false"] {
    transform: translateY(calc(100% - 60px));
  }

  .metadata-drawer[data-visible="true"] {
    transform: translateY(0);
  }

  .drawer-handle {
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .drawer-toggle {
    background: none;
    border: none;
    color: var(--color-white);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    width: 100%;
    padding: var(--spacing-xs);
    border-radius: calc(var(--border-radius) / 2);
    transition: var(--transition);
  }

  .drawer-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .chevron-icon {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .metadata-drawer[data-visible="false"] .chevron-icon {
    transform: rotate(180deg);
  }

  .handle-text {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .drawer-content {
    padding: var(--spacing-lg);
    overflow-y: auto;
    max-height: calc(70vh - 60px);
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.3) transparent;
