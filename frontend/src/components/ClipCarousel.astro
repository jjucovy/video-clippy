---
interface Props {
  clips: any[];
  pieceTitle: string;
}

const { clips, pieceTitle } = Astro.props;

// Sort clips chronologically by performance date, then by creation date
const sortedClips = clips.sort((a, b) => {
  if (a.performance?.date && b.performance?.date) {
    return new Date(a.performance.date).getTime() - new Date(b.performance.date).getTime();
  }
  if (a.performance?.date) return -1;
  if (b.performance?.date) return 1;
  return new Date(a.created_at).getTime() - new Date(b.created_at).getTime();
});
---

<div class="clip-carousel-container" data-clips={JSON.stringify(sortedClips)}>
  {sortedClips.length === 0 ? (
    <div class="empty-state">
      <h3>No clips available</h3>
      <p>There are no clips for this dance work yet. Check back soon!</p>
    </div>
  ) : (
    <>
      <div class="carousel-header">
        <h2 class="carousel-title">
          <span class="piece-title">{pieceTitle}</span>
          <span class="clip-counter">
            <span class="current-clip">1</span> of {sortedClips.length}
          </span>
        </h2>
        <p class="carousel-subtitle">Navigate through performances chronologically</p>
      </div>

      <div class="carousel-main">
        <div class="video-section">
          <div class="carousel-nav">
            <button class="nav-button prev-button" title="Previous clip" disabled>
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
              </svg>
            </button>
            <button class="nav-button next-button" title="Next clip">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
              </svg>
            </button>
          </div>

          <div class="video-players-container">
            {sortedClips.map((clip, index) => {
              const playerId = `video-player-clip-${index}`;
              const isMP4 = clip.is_extracted || (clip.video_url && clip.video_url.endsWith('.mp4'));
              return (
                <div
                  class={`video-player-wrapper ${index === 0 ? 'active' : 'hidden'}`}
                  data-clip-index={index}
                  data-is-mp4={isMP4 ? 'true' : 'false'}
                >
                  {!isMP4 && <link href="https://vjs.zencdn.net/8.6.1/video-js.css" rel="stylesheet" />}
                  <div class="video-container">
                    {isMP4 ? (
                      <video
                        id={playerId}
                        controls
                        preload="auto"
                        width="800"
                        height="450"
                        poster={clip.thumbnail_url}
                      >
                        <source src={clip.video_url} type="video/mp4" />
                      </video>
                    ) : (
                      <video
                        id={playerId}
                        class="video-js vjs-default-skin"
                        controls
                        preload="auto"
                        width="800"
                        height="450"
                        poster={clip.thumbnail_url || clip.video.cloudflare_thumbnail_url}
                        data-setup="{}"
                        data-stream-id={clip.video.cloudflare_stream_id}
                        data-start-time={clip.start_time_seconds}
                        data-end-time={clip.end_time_seconds}
                      >
                        <source src={clip.video_url || clip.video.cloudflare_playback_url} type="application/x-mpegURL" />
                        <p class="vjs-no-js">
                          To view this video please enable JavaScript, and consider upgrading to a
                          <a href="https://videojs.com/html5-video-support/" target="_blank">web browser that
                          <span class="vjs-no-js-link">supports HTML5 video</span></a>.
                        </p>
                      </video>
                    )}
                    <p class="video-title">{clip.title}</p>
                  </div>
                </div>
              );
            })}
          </div>

          <div class="carousel-thumbnails">
            {sortedClips.map((clip, index) => (
              <button 
                class={`thumbnail-button ${index === 0 ? 'active' : ''}`}
                data-clip-index={index}
                title={clip.title}
              >
                <img
                  src={clip.thumbnail_url || clip.video.cloudflare_thumbnail_url}
                  alt={clip.title}
                  loading="lazy"
                />
                <span class="thumbnail-overlay">{index + 1}</span>
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Metadata Drawer - Overlay on sidebar -->
      <div class="metadata-drawer" data-visible="true">
    <div class="drawer-handle">
      <button class="drawer-toggle" title="Toggle metadata panel">
        <svg class="chevron-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"/>
        </svg>
        <span class="handle-text">Clip Details</span>
      </button>
    </div>
    
    <div class="drawer-content">
      <div class="metadata-content">
        <h3 class="clip-title" data-field="title">{sortedClips[0]?.title}</h3>
        
        <div class="metadata-grid">
          <div class="metadata-item">
            <span class="label">Duration</span>
            <span class="value" data-field="duration">{sortedClips[0]?.duration_formatted}s</span>
          </div>
          
          <div class="metadata-item">
            <span class="label">Created</span>
            <span class="value" data-field="created">{new Date(sortedClips[0]?.created_at).toLocaleDateString()}</span>
          </div>
          
          {sortedClips[0]?.performance ? (
            <>
              <div class="metadata-item">
                <span class="label">Performance</span>
                <span class="value" data-field="performance">{sortedClips[0].performance.title}</span>
              </div>
              
              {sortedClips[0].performance.date && (
                <div class="metadata-item">
                  <span class="label">Date</span>
                  <span class="value" data-field="date">{new Date(sortedClips[0].performance.date).toLocaleDateString()}</span>
                </div>
              )}
              
              {sortedClips[0].performance.venue && (
                <div class="metadata-item">
                  <span class="label">Venue</span>
                  <span class="value" data-field="venue">{sortedClips[0].performance.venue.name}</span>
                </div>
              )}
            </>
          ) : (
            <div class="metadata-item">
              <span class="label">Performance</span>
              <span class="value missing" data-field="performance">Not specified</span>
            </div>
          )}
          
          {sortedClips[0]?.verification_date && (
            <div class="metadata-item">
              <span class="label">Verified</span>
              <span class="value" data-field="verified">{new Date(sortedClips[0].verification_date).toLocaleDateString()}</span>
            </div>
          )}
        </div>

        {sortedClips[0]?.description ? (
          <div class="description">
            <span class="label">Description</span>
            <p class="value" data-field="description">{sortedClips[0].description}</p>
          </div>
        ) : (
          <div class="description">
            <span class="label">Description</span>
            <p class="value missing" data-field="description">No description provided</p>
          </div>
        )}

        {/* Performers section */}
        <div class="performers-section">
          <span class="label">Performers</span>
          {sortedClips[0]?.clip_performers && sortedClips[0].clip_performers.length > 0 ? (
            <div class="performers-list" data-field="performers">
              {sortedClips[0].clip_performers.map((performer) => (
                <span class="performer-tag">{performer.person?.name}</span>
              ))}
            </div>
          ) : (
            <div class="performers-list" data-field="performers">
              <span class="value missing">No performers listed</span>
            </div>
          )}
        </div>

        {/* Video metadata */}
        <div class="video-metadata">
          <span class="label">Source Video</span>
          <div class="video-info">
            <p class="video-title">{sortedClips[0]?.video?.title}</p>
            {sortedClips[0]?.video?.description && (
              <p class="video-description">{sortedClips[0].video.description}</p>
            )}
            <p class="video-details">
              {sortedClips[0]?.video?.duration_formatted} • 
              Uploaded {new Date(sortedClips[0]?.video?.upload_date).toLocaleDateString()}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
    </>
  )}
</div>

<style>
  .clip-carousel-container {
    background: transparent;
    overflow: visible;
  }

  .carousel-header {
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-light-gray);
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .carousel-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-sm);
  }

  .piece-title {
    font-size: 1.5rem;
    color: var(--color-dark);
  }

  .clip-counter {
    font-size: 0.9rem;
    color: var(--color-text-light);
    font-weight: 400;
    background: var(--color-light-gray);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: calc(var(--border-radius) / 2);
  }

