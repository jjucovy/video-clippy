    border: 1px solid var(--color-light-gray);
  }

  .video-title {
    font-weight: 600;
    color: var(--color-dark);
    margin: 0 0 var(--spacing-xs) 0;
    font-size: 0.9rem;
  }

  .video-description {
    color: var(--color-text);
    margin: 0 0 var(--spacing-xs) 0;
    font-size: 0.85rem;
    font-style: italic;
  }

  .video-details {
    color: var(--color-text-light);
    margin: 0;
    font-size: 0.8rem;
  }

  .empty-state {
    padding: var(--spacing-xl);
    text-align: center;
    color: var(--color-text-light);
  }

  .empty-state h3 {
