    font-size: 0.7rem;
  }

  /* Responsive design */
  @media (max-width: 1024px) {
    .metadata-drawer {
      width: 100%;
      left: 0;
    }
  }

  @media (max-width: 768px) {
    .carousel-title {
      flex-direction: column;
      gap: var(--spacing-sm);
    }

    .piece-title {
      font-size: 1.25rem;
    }

    .video-section,
    .metadata-panel {
      padding: var(--spacing-md);
    }

    .metadata-item {
      grid-template-columns: 1fr;
      gap: var(--spacing-xs);
    }

    .nav-button {
      width: 40px;
      height: 40px;
    }

    .nav-button svg {
      width: 20px;
      height: 20px;
    }
  }
</style>

<script>
  import { initializeVideoJsPlayer } from '@/utils/videojs-player';

  class ClipCarousel {
    private container: HTMLElement;
    private clips: any[];
    private currentIndex: number = 0;
    private players: Map<number, any> = new Map();

    constructor(container: HTMLElement) {
      this.container = container;
      this.clips = JSON.parse(container.dataset.clips || '[]');
      this.init();
    }

    async init() {
      await this.initializeAllPlayers();
      this.bindEvents();
      this.bindDrawerEvents();
      this.updateMetadata();
      this.showCurrentVideo();

      // Ensure initial clip is seeked to its start time
      // (handles race condition where metadata loaded before event handler was attached)
      this.seekToClipStart(this.currentIndex);
    }

    async initializeAllPlayers() {
      const videoWrappers = this.container.querySelectorAll('.video-player-wrapper');

      for (let i = 0; i < videoWrappers.length; i++) {
        const wrapper = videoWrappers[i] as HTMLElement;
        const videoElement = wrapper.querySelector('video');
        if (!videoElement) continue;

        const isMP4 = wrapper.dataset.isMp4 === 'true';

        if (isMP4) {
          // Native HTML5 player — no Video.js needed
          this.players.set(i, {
            play: () => videoElement.play(),
            pause: () => videoElement.pause(),
            paused: () => videoElement.paused,
            currentTime: (t?: number) => { if (t !== undefined) videoElement.currentTime = t; return videoElement.currentTime; },
            duration: () => videoElement.duration,
          });
        } else {
          // Video.js player for CF Stream HLS
          const playerId = videoElement.id;
          const startTime = parseFloat(videoElement.dataset.startTime || '0');
          const endTime = parseFloat(videoElement.dataset.endTime || '0');

          try {
            const player = await initializeVideoJsPlayer({
              playerId,
              startTime: !isNaN(startTime) ? startTime : undefined,
              endTime: !isNaN(endTime) ? endTime : undefined,
              autoLoopToStart: true,
              remapTimeline: false,
            });
            this.players.set(i, player);
          } catch (error) {
            console.error('Failed to initialize player', playerId, error);
          }
        }
      }
    }

    bindEvents() {
      // Navigation buttons
      const prevBtn = this.container.querySelector('.prev-button');
      const nextBtn = this.container.querySelector('.next-button');
      
      prevBtn?.addEventListener('click', () => this.previousClip());
      nextBtn?.addEventListener('click', () => this.nextClip());

      // Thumbnail buttons
      const thumbnails = this.container.querySelectorAll('.thumbnail-button');
      thumbnails.forEach((btn, index) => {
        btn.addEventListener('click', () => this.goToClip(index));
      });

      // Keyboard navigation
      document.addEventListener('keydown', (e) => {
        if (e.target.closest('.clip-carousel-container') === this.container) {
          if (e.key === 'ArrowLeft') this.previousClip();
          if (e.key === 'ArrowRight') this.nextClip();
        }
      });
    }

    bindDrawerEvents() {
      const drawer = document.querySelector('.metadata-drawer');
      const drawerToggle = drawer?.querySelector('.drawer-toggle');
      
      if (drawerToggle) {
        drawerToggle.addEventListener('click', () => {
          const currentState = drawer.getAttribute('data-visible');
          const newState = currentState === 'true' ? 'false' : 'true';
          drawer.setAttribute('data-visible', newState);
        });
      }
    }

    previousClip() {
      if (this.currentIndex > 0) {
        this.goToClip(this.currentIndex - 1);
      }
    }

    nextClip() {
      if (this.currentIndex < this.clips.length - 1) {
        this.goToClip(this.currentIndex + 1);
      }
    }

    goToClip(index: number) {
      // Pause the current video
      const currentPlayer = this.players.get(this.currentIndex);
      if (currentPlayer) {
        currentPlayer.pause();
      }

      this.currentIndex = index;
      this.showCurrentVideo();

      // Seek the new player to its clip start time
      this.seekToClipStart(index);

      this.animateMetadataUpdate(() => {
        this.updateMetadata();
      });
      this.updateThumbnails();
      this.updateNavigation();
      this.updateCounter();
    }

    seekToClipStart(index: number) {
      const player = this.players.get(index);
      const clip = this.clips[index];
      if (player && clip) {
        // Extracted clips are standalone — always start at 0
        if (clip.is_extracted) {
          player.currentTime(0);
          return;
        }
        const startTime = parseFloat(clip.start_time_seconds);
        if (!isNaN(startTime) && startTime > 0) {
          player.currentTime(startTime);
        }
      }
    }

    showCurrentVideo() {
      const videoWrappers = this.container.querySelectorAll('.video-player-wrapper');
      videoWrappers.forEach((wrapper, index) => {
        if (index === this.currentIndex) {
          wrapper.classList.remove('hidden');
          wrapper.classList.add('active');
        } else {
          wrapper.classList.add('hidden');
          wrapper.classList.remove('active');
        }
      });
    }

    animateMetadataUpdate(callback: () => void) {
      const drawer = document.querySelector('.metadata-drawer');
      const content = drawer?.querySelector('.drawer-content') as HTMLElement | null;

      if (content) {
        // Slide down slightly
        content.style.transform = 'translateY(10px)';
        content.style.opacity = '0.7';

        setTimeout(() => {
          callback();
          // Slide back up
          content.style.transform = 'translateY(0)';
          content.style.opacity = '1';
        }, 150);
      } else {
        callback();
      }
    }

    updateMetadata() {
      const clip = this.clips[this.currentIndex];
      
      // Update basic fields
      this.updateField('title', clip.title);
      this.updateField('duration', `${clip.duration_formatted}s`);
      this.updateField('created', new Date(clip.created_at).toLocaleDateString());
      
      // Update description (handle missing)
      const descriptionEl = this.container.querySelector('[data-field="description"]');
      if (descriptionEl) {
        if (clip.description) {
          descriptionEl.textContent = clip.description;
          descriptionEl.classList.remove('missing');
        } else {
          descriptionEl.textContent = 'No description provided';
          descriptionEl.classList.add('missing');
        }
      }
      
      // Update performance-related fields
      const performanceEl = this.container.querySelector('[data-field="performance"]');
      if (performanceEl) {
        if (clip.performance) {
          performanceEl.textContent = clip.performance.title;
          performanceEl.classList.remove('missing');
          
          // Update date and venue if they exist
          if (clip.performance.date) {
            this.updateField('date', new Date(clip.performance.date).toLocaleDateString());
          }
          if (clip.performance.venue) {
            this.updateField('venue', clip.performance.venue.name);
          }
        } else {
          performanceEl.textContent = 'Not specified';
          performanceEl.classList.add('missing');
        }
      }

      // Update verification date
      if (clip.verification_date) {
        this.updateField('verified', new Date(clip.verification_date).toLocaleDateString());
      }

      // Update performers
      const performersContainer = this.container.querySelector('[data-field="performers"]');
      if (performersContainer) {
        const hasPerformers = clip.clip_performers && clip.clip_performers.length > 0;

        if (hasPerformers) {
          const performerTags = clip.clip_performers.map(p => `<span class="performer-tag">${p.person?.name}</span>`);
          performersContainer.innerHTML = performerTags.join('');
        } else {
          performersContainer.innerHTML = '<span class="value missing">No performers listed</span>';
        }
      }

      // Update video metadata
      const videoTitleEl = this.container.querySelector('.video-title');
      const videoDescEl = this.container.querySelector('.video-description');
      const videoDetailsEl = this.container.querySelector('.video-details');
      
      if (videoTitleEl) videoTitleEl.textContent = clip.video?.title || 'Unknown';
      if (videoDescEl && clip.video?.description) {
        videoDescEl.textContent = clip.video.description;
        videoDescEl.style.display = 'block';
      } else if (videoDescEl) {
        videoDescEl.style.display = 'none';
      }
      if (videoDetailsEl) {
        videoDetailsEl.textContent = `${clip.video?.duration_formatted || 'Unknown'} • Uploaded ${new Date(clip.video?.upload_date).toLocaleDateString()}`;
      }
    }

    updateField(fieldName, value) {
      const element = this.container.querySelector(`[data-field="${fieldName}"]`);
      if (element && value) {
        element.textContent = value;
      }
    }

    updateThumbnails() {
      const thumbnails = this.container.querySelectorAll('.thumbnail-button');
      thumbnails.forEach((btn, index) => {
        btn.classList.toggle('active', index === this.currentIndex);
      });
    }

    updateNavigation() {
      const prevBtn = this.container.querySelector('.prev-button');
      const nextBtn = this.container.querySelector('.next-button');
      
      if (prevBtn) prevBtn.disabled = this.currentIndex === 0;
      if (nextBtn) nextBtn.disabled = this.currentIndex === this.clips.length - 1;
    }

    updateCounter() {
      const currentClipElement = this.container.querySelector('.current-clip');
      if (currentClipElement) {
        currentClipElement.textContent = this.currentIndex + 1;
      }
    }
  }

  // Initialize carousels when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    const carousels = document.querySelectorAll('.clip-carousel-container');
    carousels.forEach(container => new ClipCarousel(container));
  });
</script>