  .metadata-drawer .performer-tag {
    background: rgba(131, 205, 192, 0.2);
    color: var(--color-secondary);
    border: 1px solid rgba(131, 205, 192, 0.3);
  }

  .metadata-drawer .video-info {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .metadata-drawer .video-title {
    color: var(--color-white);
  }

  .metadata-drawer .video-description {
    color: rgba(255, 255, 255, 0.8);
  }

  .metadata-drawer .video-details {
    color: rgba(255, 255, 255, 0.6);
  }

  .clip-title {
    color: var(--color-dark);
    margin-bottom: var(--spacing-lg);
    font-size: 1.25rem;
  }

  .metadata-grid {
    display: grid;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .metadata-item {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--spacing-sm);
    align-items: start;
