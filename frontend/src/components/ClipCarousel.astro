    color: var(--color-secondary);
    font-weight: 600;
  }

  .carousel-subtitle {
    color: var(--color-text-light);
    font-style: italic;
    font-size: 0.9rem;
    margin: 0;
  }

  .carousel-main {
    min-height: 600px;
  }

  .video-section {
    position: relative;
    padding: var(--spacing-lg);
  }

  .carousel-nav {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 var(--spacing-md);
    pointer-events: none;
    z-index: 10;
  }

  .nav-button {
    pointer-events: all;
    background: rgba(255, 255, 255, 0.9);
    border: 2px solid var(--color-light-gray);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    color: var(--color-dark);
