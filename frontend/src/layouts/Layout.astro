---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Dance Visions NY - Bringing Isadora Duncan's artistic legacy into the present" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Dance Visions NY Video Archive</title>
	</head>
	<body>
		<header id="masthead">
			<div class="masthead-brand">
				<a href="/" class="brand-link">
					<span class="brand-name">Dance Visions NY</span>
					<span class="brand-sub">Video Archive</span>
				</a>
			</div>

			<nav class="masthead-nav" aria-label="Main navigation">
				<ul class="nav-list">
					<li><a href="/" class="nav-link" data-path="/">Home</a></li>
					<li><a href="/performances" class="nav-link" data-path="/performances">Performances</a></li>
					<li><a href="/performers" class="nav-link" data-path="/performers">Performers</a></li>
					<li><a href="/dance-works" class="nav-link" data-path="/dance-works">Dance Works</a></li>
					<li><a href="/clips" class="nav-link" data-path="/clips">Clips</a></li>
					<li><a href="/videos" class="nav-link" data-path="/videos">Videos</a></li>
					<li><a href="/venues" class="nav-link" data-path="/venues">Venues</a></li>
				</ul>
			</nav>

			<button class="mobile-menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
				<span></span>
				<span></span>
				<span></span>
			</button>
		</header>

		<main class="main-content">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<p class="footer-copy">&copy; 2025 Dance Visions NY</p>
				<p class="footer-grant">
					This work is supported by Long Island Grants for the Arts through funds provided by the
					office of the Governor and the New York State Legislature, and administered by
					The Huntington Arts Council.
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	@import '../styles/global.css';
</style>

<style>
/* ── Masthead ── */
#masthead {
	display: flex;
	align-items: center;
	justify-content: space-between;
	background: #fff;
	border-bottom: 2px solid var(--color-primary);
	padding: 0.6rem 2rem;
	position: sticky;
	top: 0;
	z-index: 100;
	box-shadow: 0 2px 8px rgba(0,0,0,0.07);
	flex-wrap: wrap;
	gap: 0.5rem;
}

.masthead-brand {
	flex-shrink: 0;
}

.brand-link {
	display: flex;
	flex-direction: column;
	text-decoration: none;
	line-height: 1.2;
}

.brand-link:hover { text-decoration: none; }

.brand-name {
	font-family: var(--font-body);
	font-weight: bold;
	font-size: 1.15rem;
	color: var(--color-dark);
	letter-spacing: 0.01em;
}

.brand-sub {
	font-size: 0.68rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.18em;
	color: var(--color-primary);
}

/* ── Nav ── */
.masthead-nav { flex: 1; display: flex; justify-content: flex-end; }

.nav-list {
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	gap: 0.15rem;
	margin: 0;
	padding: 0;
	list-style: none;
	align-items: center;
	justify-content: flex-end;
}

.nav-link {
	display: inline-block;
	padding: 0.45rem 0.85rem;
	font-weight: bold;
	font-size: 0.78rem;
	text-transform: uppercase;
	letter-spacing: 0.09em;
	color: var(--color-dark);
	text-decoration: none;
	border-radius: var(--button-radius);
	border: 1px solid transparent;
	transition: var(--transition);
}

.nav-link:hover {
	color: #000;
	background: var(--color-primary);
	border-color: var(--color-primary);
	text-decoration: none;
}

.nav-link.active {
	color: #000;
	background: var(--color-primary);
	border-color: var(--color-primary);
}

/* ── Mobile toggle ── */
.mobile-menu-toggle {
	display: none;
	background: none;
	border: 1px solid var(--color-light-gray);
	border-radius: var(--button-radius);
	padding: 0.4rem 0.6rem;
	cursor: pointer;
	flex-direction: column;
	gap: 4px;
	align-items: center;
}

.mobile-menu-toggle span {
	display: block;
	width: 22px;
	height: 2px;
	background: var(--color-dark);
	transition: var(--transition);
}

/* ── Main content ── */
.main-content {
	max-width: 1200px;
	margin: 0 auto;
	padding: var(--spacing-xl) var(--spacing-lg);
	min-height: calc(100vh - 56px - 100px);
}

/* ── Footer ── */
.site-footer {
	background: var(--color-dark);
	color: rgba(255,255,255,0.75);
	padding: var(--spacing-lg) var(--spacing-lg);
	margin-top: var(--spacing-2xl);
}

.footer-inner {
	max-width: 1200px;
	margin: 0 auto;
	text-align: center;
}

.footer-copy {
	font-weight: bold;
	font-size: 0.85rem;
	text-transform: uppercase;
	letter-spacing: 0.1em;
	color: rgba(255,255,255,0.9);
	margin-bottom: 0.5rem;
}

.footer-grant {
	font-size: 0.78rem;
	color: rgba(255,255,255,0.5);
	max-width: 600px;
	margin: 0 auto;
	line-height: 1.6;
}

/* ── Responsive ── */
@media (max-width: 768px) {
	#masthead {
		padding: 0.6rem 1rem;
		position: relative;
	}

	.masthead-nav {
		width: 100%;
		order: 3;
		display: none;
	}

	.masthead-nav.open {
		display: flex;
	}

	.nav-list {
		flex-direction: column;
		align-items: flex-start;
		width: 100%;
		gap: 0;
		padding: 0.5rem 0;
		border-top: 1px solid var(--color-light-gray);
	}

	.nav-link {
		width: 100%;
		padding: 0.65rem 0.5rem;
	}

	.mobile-menu-toggle {
		display: flex;
	}

	.main-content {
		padding: var(--spacing-lg) var(--spacing-sm);
	}
}

@media (max-width: 480px) {
	.main-content {
		padding: var(--spacing-md) var(--spacing-xs);
	}
}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		// Active nav link detection
		const navLinks = document.querySelectorAll('.nav-link[data-path]');
		const currentPath = window.location.pathname;
		navLinks.forEach(link => {
			const linkPath = link.getAttribute('data-path');
			const isActive = linkPath === '/'
				? currentPath === '/'
				: currentPath.startsWith(linkPath ?? '');
			if (isActive) link.classList.add('active');
		});

		// Mobile menu toggle
		const toggle = document.querySelector('.mobile-menu-toggle');
		const nav = document.querySelector('.masthead-nav');

		if (toggle && nav) {
			toggle.addEventListener('click', () => {
				const open = nav.classList.toggle('open');
				toggle.setAttribute('aria-expanded', String(open));
			});
		}
	});
</script>
