---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Dance Visions NY - Bringing Isadora Duncan’s artistic legacy into the present" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Dance Visions NY Video Archive</title>
	</head>
	<body>
		<div class="site-layout">
			<aside class="sidebar">
				<div class="sidebar-content">
					<div class="logo">
						<a href="/">
							<h1 class="site-title">Dance Visions NY</h1>
							<p class="site-subtitle">Video Archive</p>
						</a>
					</div>
					
					<nav class="sidebar-nav">
						<ul class="nav-list">
							<li>
								<a href="/" class="nav-link" data-path="/">
									<svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
									Home
								</a>
							</li>
							<li>
								<a href="/performances" class="nav-link" data-path="/performances">
									<svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
									Performances
								</a>
							</li>
							<li>
								<a href="/performers" class="nav-link" data-path="/performers">
									<svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v1h8v-1zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-1a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v1h-3zM4.75 14.094A5.973 5.973 0 004 17v1H1v-1a3 3 0 013.75-2.906z"/></svg>
									Performers
								</a>
							</li>
							<li>
								<a href="/dance-works" class="nav-link" data-path="/dance-works">
									<svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/></svg>
									Dance Works
								</a>
							</li>
							<li>
								<a href="/clips" class="nav-link" data-path="/clips">
									<svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/></svg>
									Clips
								</a>
							</li>
							<li>
								<a href="/videos" class="nav-link" data-path="/videos">
									<svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zm12.553.106A1 1 0 0014 7v6a1 1 0 00.553.894l2 1A1 1 0 0018 14V6a1 1 0 00-1.447-.894l-2 1z"/></svg>
									Videos
								</a>
							</li>
							<li>
								<a href="/venues" class="nav-link" data-path="/venues">
									<svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd"/></svg>
									Venues
								</a>
							</li>
						</ul>
					</nav>
					
					<div class="sidebar-footer">
                                             
					     	<p class="copyright">&copy; 2025 Dance Visions NY</p>
                                                <p class="copyright" style="text-align:justify">
                                                This work is supported by Long Island Grants for the Arts through funds provided by the office of the Governor and the New York State Legislature, and administered by The Huntington Arts Council.
                                                </p>
					</div>
				</div>
			</aside>
			
			<div class="main-wrapper">
				<main class="main-content">
					<slot />
				</main>
			</div>
		</div>
		
		<!-- Mobile menu toggle -->
		<button class="mobile-menu-toggle" aria-label="Toggle navigation">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</body>
</html>

<style is:global>
	@import '../styles/global.css';
</style>

<style>
	.site-layout {
		display: flex;
		min-height: 100vh;
	}
	
	.sidebar {
		width: 20%;
		background: var(--color-sidebar-bg);
		border-right: none;
		position: fixed;
		top: 0;
		left: 0;
		height: 100vh;
		overflow-y: auto;
		z-index: 100;
		box-shadow: 4px 0 24px rgba(0, 0, 0, 0.25);
	}

	/* Accent stripe at top */
	.sidebar::before {
		content: '';
		display: block;
		height: 3px;
		background: linear-gradient(90deg, var(--color-sidebar-accent) 0%, var(--color-accent-lavender) 100%);
		flex-shrink: 0;
	}

	.sidebar-content {
		padding: var(--spacing-xl) var(--spacing-md);
		display: flex;
		flex-direction: column;
		height: calc(100% - 3px);
	}

	.logo {
		margin-bottom: var(--spacing-xl);
		text-align: center;
		padding-bottom: var(--spacing-lg);
		border-bottom: 1px solid var(--color-sidebar-border);
	}

	.logo a {
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.logo a:hover .site-title {
		color: var(--color-sidebar-accent);
	}

	.site-title {
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
		color: var(--color-sidebar-text-bright);
		font-style: italic;
		line-height: 1.2;
		transition: color 0.2s ease;
	}

	.site-subtitle {
		font-size: 0.7rem;
		margin: 6px 0 0 0;
		color: var(--color-sidebar-accent);
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.18em;
	}

	.sidebar-nav {
		flex: 1;
	}

	.nav-list {
		display: flex;
		flex-direction: column;
		gap: 2px;
		margin: 0;
		padding: 0;
	}

	.nav-link {
		font-weight: 500;
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.75rem var(--spacing-md);
		border-radius: var(--border-radius-sm);
		transition: var(--transition);
		display: flex;
		align-items: center;
		gap: 0.65rem;
		color: var(--color-sidebar-text);
		border-left: 3px solid transparent;
	}

	.nav-icon {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		opacity: 0.7;
		transition: opacity 0.2s ease;
	}

	.nav-link:hover {
		background: var(--color-sidebar-hover);
		color: var(--color-sidebar-accent);
		border-left-color: var(--color-sidebar-accent);
		transform: translateX(3px);
	}

	.nav-link:hover .nav-icon {
		opacity: 1;
	}

	.nav-link.active {
		background: var(--color-sidebar-active);
		color: var(--color-sidebar-accent);
		border-left-color: var(--color-sidebar-accent);
		font-weight: 600;
	}

	.nav-link.active .nav-icon {
		opacity: 1;
	}

	.sidebar-footer {
		padding-top: var(--spacing-lg);
		border-top: 1px solid var(--color-sidebar-border);
		text-align: center;
		margin-top: auto;
	}

	.copyright {
		font-size: 0.72rem;
		color: rgba(232, 224, 216, 0.35);
		margin: 0 0 var(--spacing-xs) 0;
		font-weight: 400;
		line-height: 1.5;
	}

	.main-wrapper {
		width: 80%;
		margin-left: 20%;
		min-height: 100vh;
		background: var(--color-primary);
	}

	.main-content {
		padding: var(--spacing-xl);
		max-width: none;
	}

	.mobile-menu-toggle {
		display: none;
		position: fixed;
		top: var(--spacing-md);
		left: var(--spacing-md);
		z-index: 200;
		background: var(--color-sidebar-bg);
		border: 1px solid var(--color-sidebar-border);
		border-radius: var(--border-radius-sm);
		padding: var(--spacing-xs);
		width: 40px;
		height: 40px;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		cursor: pointer;
		box-shadow: var(--shadow-md);
	}

	.mobile-menu-toggle span {
		display: block;
		height: 2px;
		width: 20px;
		background: var(--color-sidebar-text-bright);
		transition: var(--transition);
		margin: 0 auto;
	}

	.mobile-menu-toggle:hover span {
		background: var(--color-sidebar-accent);
	}

	/* Responsive design */
	@media (max-width: 768px) {
		.sidebar {
			width: 280px;
			transform: translateX(-100%);
			transition: transform 0.3s ease;
		}

		.sidebar.open {
			transform: translateX(0);
		}

		.main-wrapper {
			width: 100%;
			margin-left: 0;
		}

		.main-content {
			padding: var(--spacing-lg);
			padding-top: 80px;
		}

		.mobile-menu-toggle {
			display: flex;
		}

		.site-title {
			font-size: 1.4rem;
		}

		.nav-link {
			padding: 0.875rem var(--spacing-md);
		}
	}

	@media (max-width: 480px) {
		.main-content {
			padding: var(--spacing-md);
			padding-top: 80px;
		}

		.sidebar {
			width: 100%;
		}

		.sidebar-content {
			padding: var(--spacing-lg) var(--spacing-md);
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		// Active nav link detection
		const navLinks = document.querySelectorAll('.nav-link[data-path]');
		const currentPath = window.location.pathname;
		navLinks.forEach(link => {
			const linkPath = link.getAttribute('data-path');
			const isActive = linkPath === '/'
				? currentPath === '/'
				: currentPath.startsWith(linkPath);
			if (isActive) link.classList.add('active');
		});

		// Mobile menu toggle functionality
		const mobileToggle = document.querySelector('.mobile-menu-toggle');
		const sidebar = document.querySelector('.sidebar');

		if (mobileToggle && sidebar) {
			mobileToggle.addEventListener('click', () => {
				sidebar.classList.toggle('open');
			});

			document.addEventListener('click', (e) => {
				if (window.innerWidth <= 768) {
					if (!sidebar.contains(e.target) && !mobileToggle.contains(e.target)) {
						sidebar.classList.remove('open');
					}
				}
			});

			window.addEventListener('resize', () => {
				if (window.innerWidth > 768) {
					sidebar.classList.remove('open');
				}
			});
		}
	});
</script>
