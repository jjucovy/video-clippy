---
export const prerender = false;
import Layout from '@/layouts/Layout.astro';
import { list } from '@/lib/api';

const url = new URL(Astro.request.url);
const genreFilter = url.searchParams.get('genre');

const customFields = await list('custom-fields');
const genreField = customFields.find((f: any) => f.name === 'Genre');
const genres: string[] = genreField?.choices || [];

let clips: any[];
if (genreFilter) {
	const pieces = await list(`pieces?custom_Genre=${encodeURIComponent(genreFilter)}`);
	const pieceIds = pieces.map((p: any) => p.id);
	if (pieceIds.length > 0) {
		const allClips = await list('clips');
		clips = allClips.filter((c: any) => c.piece && pieceIds.includes(c.piece.id));
	} else {
		clips = [];
	}
} else {
	clips = await list('clips');
}

clips = clips.sort((a: any, b: any) => a.title.localeCompare(b.title));
---

<Layout title="Clips">
	<div class="page-header">
		<span class="section-eyebrow">Archive</span>
		<h1>Video Clips</h1>
		<p class="page-subtitle">Curated footage spanning 35 years of performance</p>
	</div>

	{genres.length > 0 && (
		<div class="filters">
			<span class="filter-label">Genre</span>
			<a href="/clips" class:list={["filter-btn", { active: !genreFilter }]}>All</a>
			{genres.map((genre) => (
				<a href={`/clips?genre=${encodeURIComponent(genre)}`}
				   class:list={["filter-btn", { active: genreFilter === genre }]}>
					{genre}
				</a>
			))}
		</div>
	)}

	{clips.length === 0 ? (
		<div class="empty-state">
			<p>No clips found{genreFilter ? ` in "${genreFilter}"` : ''}.</p>
		</div>
	) : (
		<div class="clips-grid">
			{clips.map((clip) => {
				const thumb = clip.thumbnail_url || clip.video?.cloudflare_thumbnail_url;
				const genre = clip.piece?.custom_fields?.Genre?.value;
				return (
					<article class="clip-card">
						<a href={`/clips/${clip.id}`} class="clip-link">
							<div class="clip-thumb">
								{thumb
									? <img src={thumb} alt={clip.title} loading="lazy" />
									: <div class="thumb-placeholder"><span>▶</span></div>
								}
								<div class="clip-overlay">
									<span class="play-btn">▶</span>
								</div>
								{clip.duration_formatted && (
									<span class="duration-badge">{clip.duration_formatted}s</span>
								)}
								{genre && <span class="genre-badge">{genre}</span>}
							</div>
							<div class="clip-info">
								<h3 class="clip-title">{clip.title}</h3>
								{clip.performance && (
									<p class="clip-perf">{clip.performance.title}</p>
								)}
							</div>
						</a>
					</article>
				);
			})}
		</div>
	)}
</Layout>

<style>
.clips-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
	gap: var(--spacing-md);
}

.clip-card {
	background: var(--color-bg-card);
	border-radius: var(--border-radius);
	overflow: hidden;
	box-shadow: var(--shadow-card);
	transition: var(--transition);
}

.clip-card:hover {
	transform: translateY(-5px);
	box-shadow: var(--shadow-card-hover);
}

.clip-link { display: block; color: inherit; text-decoration: none; }

/* Thumbnail */
.clip-thumb {
	position: relative;
	aspect-ratio: 16 / 9;
	background: var(--color-dark);
	overflow: hidden;
}

.clip-thumb img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
	transition: transform 0.4s ease;
}

.clip-card:hover .clip-thumb img { transform: scale(1.05); }

.thumb-placeholder {
	width: 100%;
	height: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	background: linear-gradient(135deg, #1a1820 0%, #2e2b35 100%);
}

.thumb-placeholder span {
	font-size: 2rem;
	opacity: 0.2;
	color: white;
}

/* Overlay */
.clip-overlay {
	position: absolute;
	inset: 0;
	background: rgba(20, 18, 32, 0.45);
	display: flex;
	align-items: center;
	justify-content: center;
	opacity: 0;
	transition: var(--transition);
}

.clip-card:hover .clip-overlay { opacity: 1; }

.play-btn {
	width: 52px;
	height: 52px;
	background: rgba(255,255,255,0.95);
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 1.1rem;
	color: var(--color-dark);
	padding-left: 3px;
	box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}

/* Badges */
.duration-badge {
	position: absolute;
	bottom: 0.5rem;
	right: 0.5rem;
	background: rgba(20, 18, 32, 0.75);
	color: white;
	font-size: 0.7rem;
	font-weight: 600;
	padding: 0.2rem 0.5rem;
	border-radius: var(--border-radius-sm);
	letter-spacing: 0.05em;
}

.genre-badge {
	position: absolute;
	top: 0.5rem;
	left: 0.5rem;
	background: var(--color-accent-purple);
	color: white;
	font-size: 0.65rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.1em;
	padding: 0.2rem 0.6rem;
	border-radius: var(--border-radius-pill);
}

/* Info */
.clip-info {
	padding: var(--spacing-md);
}

.clip-title {
	font-size: 1rem;
	margin: 0 0 0.3rem;
	color: var(--color-dark);
	line-height: 1.35;
	font-style: italic;
}

.clip-perf {
	font-size: 0.78rem;
	color: var(--color-text-muted);
	margin: 0;
	font-weight: 500;
	text-transform: uppercase;
	letter-spacing: 0.05em;
}

@media (max-width: 640px) {
	.clips-grid { grid-template-columns: 1fr; }
}
</style>
