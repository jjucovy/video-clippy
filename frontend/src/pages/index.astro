---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Home">

	<!-- Hero -->
	<section class="hero">
		<div class="hero-text">
			<span class="section-eyebrow">35 Years · New York City</span>
			<h1 class="hero-title">Dance<br/><em>Visions NY</em></h1>
			<p class="hero-sub">Video Archive</p>
		</div>
		<div class="hero-body">
			<p class="hero-description">
				A digital archive preserving 35 years of works rooted in Isadora Duncan's legacy —
				from archival footage to contemporary performances, made accessible to researchers,
				students, artists, and audiences worldwide.
			</p>
			<div class="hero-actions">
				<a href="/performances" class="btn">Browse Performances</a>
				<a href="/clips" class="btn btn-outline">Watch Clips</a>
			</div>
		</div>
	</section>

	<!-- Navigation tiles -->
	<section class="tiles-section">
		<a href="/performances" class="tile tile--purple">
			<span class="tile-num">01</span>
			<div class="tile-content">
				<h3>Performances</h3>
				<p>Shows & events across the company's history</p>
			</div>
			<span class="tile-arrow">↗</span>
		</a>
		<a href="/dance-works" class="tile tile--teal">
			<span class="tile-num">02</span>
			<div class="tile-content">
				<h3>Dance Works</h3>
				<p>Choreographic works rooted in Duncan's legacy</p>
			</div>
			<span class="tile-arrow">↗</span>
		</a>
		<a href="/clips" class="tile tile--dark">
			<span class="tile-num">03</span>
			<div class="tile-content">
				<h3>Video Clips</h3>
				<p>Curated clips from archival & live footage</p>
			</div>
			<span class="tile-arrow">↗</span>
		</a>
		<a href="/performers" class="tile tile--rose">
			<span class="tile-num">04</span>
			<div class="tile-content">
				<h3>Performers</h3>
				<p>Dancers, choreographers, and artists</p>
			</div>
			<span class="tile-arrow">↗</span>
		</a>
	</section>

	<!-- Mission -->
	<section class="mission">
		<div class="mission-rule"></div>
		<blockquote>
			Our archive aims to build and educate by revealing the scope of the company's body
			of work — making accessible historic and contemporary art that builds on its foundation
			to researchers, students, artists, historians, and lay people.
		</blockquote>
		<cite>Dance Visions NY &nbsp;·&nbsp; Est. 1990</cite>
	</section>

</Layout>

<style>
/* ── Hero ── */
.hero {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: var(--spacing-xl);
	align-items: end;
	padding: var(--spacing-2xl) 0 var(--spacing-xl);
	border-bottom: 1px solid var(--color-light-gray);
	margin-bottom: var(--spacing-xl);
}

.hero-title {
	font-size: clamp(3rem, 6vw, 5rem);
	line-height: 1;
	margin: 0.4rem 0 0.5rem;
	letter-spacing: -0.02em;
}

.hero-title em {
	font-style: italic;
	color: var(--color-accent-purple);
}

.hero-sub {
	font-size: 0.72rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.25em;
	color: var(--color-text-muted);
	margin: 0;
}

.hero-description {
	font-size: 1.05rem;
	line-height: 1.75;
	color: var(--color-text-light);
	margin-bottom: var(--spacing-lg);
	max-width: 480px;
}

.hero-actions {
	display: flex;
	gap: var(--spacing-sm);
	flex-wrap: wrap;
}

/* ── Tiles ── */
.tiles-section {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	gap: 1px;
	background: var(--color-light-gray);
	border-radius: var(--border-radius-lg);
	overflow: hidden;
	margin-bottom: var(--spacing-xl);
}

.tile {
	position: relative;
	display: flex;
	flex-direction: column;
	justify-content: space-between;
	padding: var(--spacing-lg) var(--spacing-md);
	min-height: 220px;
	text-decoration: none;
	color: white;
	overflow: hidden;
	transition: var(--transition);
}

.tile:hover {
	transform: scale(1.02);
	z-index: 1;
	box-shadow: var(--shadow-lg);
}

.tile:hover .tile-arrow {
	transform: translate(3px, -3px);
}

.tile--purple  { background: #4a4fa0; }
.tile--teal    { background: #3a9e94; }
.tile--dark    { background: var(--color-dark); }
.tile--rose    { background: #a06060; }

.tile-num {
	font-family: var(--font-display);
	font-size: 2.5rem;
	font-weight: 700;
	opacity: 0.2;
	line-height: 1;
	margin-bottom: auto;
}

.tile-content h3 {
	color: white;
	font-size: 1.1rem;
	margin-bottom: 0.4rem;
	font-style: italic;
}

.tile-content p {
	font-size: 0.8rem;
	color: rgba(255,255,255,0.65);
	margin: 0;
	line-height: 1.4;
}

.tile-arrow {
	position: absolute;
	top: var(--spacing-md);
	right: var(--spacing-md);
	font-size: 1.2rem;
	opacity: 0.5;
	transition: var(--transition);
}

/* ── Mission ── */
.mission {
	text-align: center;
	padding: var(--spacing-xl) 0;
}

.mission-rule {
	width: 48px;
	height: 2px;
	background: var(--color-secondary);
	margin: 0 auto var(--spacing-lg);
	border-radius: 2px;
}

.mission blockquote {
	font-family: var(--font-display);
	font-style: italic;
	font-size: clamp(1.1rem, 2vw, 1.4rem);
	line-height: 1.75;
	color: var(--color-dark);
	max-width: 660px;
	margin: 0 auto var(--spacing-md);
	border: none;
	padding: 0;
}

.mission cite {
	font-size: 0.72rem;
	font-weight: 600;
	text-transform: uppercase;
	letter-spacing: 0.18em;
	color: var(--color-text-muted);
	font-style: normal;
}

/* ── Responsive ── */
@media (max-width: 900px) {
	.hero { grid-template-columns: 1fr; gap: var(--spacing-md); padding-top: var(--spacing-xl); }
	.hero-description { max-width: 100%; }
	.tiles-section { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 560px) {
	.tiles-section { grid-template-columns: 1fr; }
	.tile { min-height: 140px; }
	.hero-title { font-size: 3rem; }
}
</style>
