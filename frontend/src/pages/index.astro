---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Home">

	<!-- Hero -->
	<section class="hero">
		<h1 class="hero-title">Dance Visions NY</h1>
		<p class="hero-sub">Video Archive</p>
		<p class="hero-description">
			A digital archive preserving 35 years of works rooted in Isadora Duncan's legacy —
			from archival footage to contemporary performances, made accessible to researchers,
			students, artists, and audiences worldwide.
		</p>
		<div class="hero-actions">
			<a href="/performances" class="btn">Browse Performances</a>
			<a href="/clips" class="btn btn-secondary">Watch Clips</a>
		</div>
	</section>

	<!-- Navigation tiles -->
	<section class="tiles-section">
		<a href="/performances" class="tile">
			<h3>Performances</h3>
			<p>Shows &amp; events across the company's history</p>
			<span class="tile-arrow">→</span>
		</a>
		<a href="/dance-works" class="tile">
			<h3>Dance Works</h3>
			<p>Choreographic works rooted in Duncan's legacy</p>
			<span class="tile-arrow">→</span>
		</a>
		<a href="/clips" class="tile tile--secondary">
			<h3>Video Clips</h3>
			<p>Curated clips from archival &amp; live footage</p>
			<span class="tile-arrow">→</span>
		</a>
		<a href="/performers" class="tile">
			<h3>Performers</h3>
			<p>Dancers, choreographers, and artists</p>
			<span class="tile-arrow">→</span>
		</a>
	</section>

	<!-- Mission -->
	<section class="mission">
		<blockquote>
			Our archive aims to build and educate by revealing the scope of the company's body
			of work — making accessible historic and contemporary art that builds on its foundation
			to researchers, students, artists, historians, and lay people.
		</blockquote>
		<cite>Dance Visions NY &nbsp;·&nbsp; Est. 1990</cite>
	</section>

</Layout>

<style>
/* ── Hero ── */
.hero {
	text-align: center;
	padding: var(--spacing-2xl) 0 var(--spacing-xl);
	border-bottom: 1px solid var(--color-light-gray);
	margin-bottom: var(--spacing-xl);
}

.hero-title {
	font-size: clamp(2.2rem, 5vw, 3.5rem);
	margin-bottom: 0.25rem;
}

.hero-sub {
	font-size: 0.78rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.25em;
	color: var(--color-primary);
	margin-bottom: var(--spacing-md);
	text-align: center;
}

.hero-description {
	font-size: 1.05rem;
	line-height: 1.75;
	color: var(--color-text-light);
	max-width: 560px;
	margin: 0 auto var(--spacing-lg);
}

.hero-actions {
	display: flex;
	gap: var(--spacing-sm);
	flex-wrap: wrap;
	justify-content: center;
}

/* ── Tiles ── */
.tiles-section {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	gap: 1.5rem;
	margin-bottom: var(--spacing-xl);
}

.tile {
	display: flex;
	flex-direction: column;
	padding: var(--spacing-lg) var(--spacing-md);
	background: var(--color-bg-soft);
	border: 2px solid var(--color-primary);
	border-radius: var(--button-radius);
	text-decoration: none;
	color: var(--color-dark);
	transition: var(--transition);
	position: relative;
}

.tile:hover {
	background: var(--color-primary);
	color: #000;
	text-decoration: none;
	transform: translateY(-3px);
	box-shadow: var(--shadow-md);
}

.tile--secondary {
	border-color: var(--color-secondary);
}

.tile--secondary:hover {
	background: var(--color-secondary);
	color: #fff;
}

.tile h3 {
	text-align: left;
	font-size: 1rem;
	margin-bottom: 0.4rem;
	color: inherit;
}

.tile p {
	font-size: 0.85rem;
	color: var(--color-text-light);
	margin: 0 0 auto;
	line-height: 1.4;
	flex: 1;
}

.tile:hover p { color: inherit; opacity: 0.85; }

.tile-arrow {
	font-size: 1.2rem;
	margin-top: var(--spacing-sm);
	color: var(--color-primary);
	display: block;
	text-align: right;
}

.tile:hover .tile-arrow { color: inherit; }
.tile--secondary .tile-arrow { color: var(--color-secondary); }

/* ── Mission ── */
.mission {
	text-align: center;
	padding: var(--spacing-xl) 0;
	border-top: 1px solid var(--color-light-gray);
}

.mission blockquote {
	font-size: clamp(1rem, 2vw, 1.2rem);
	line-height: 1.8;
	color: var(--color-dark);
	max-width: 680px;
	margin: 0 auto var(--spacing-md);
	border: none;
	padding: 0;
	font-style: italic;
}

.mission cite {
	font-size: 0.72rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.18em;
	color: var(--color-text-muted);
	font-style: normal;
}

/* ── Responsive ── */
@media (max-width: 900px) {
	.tiles-section { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 560px) {
	.tiles-section { grid-template-columns: 1fr; }
	.hero { padding-top: var(--spacing-xl); }
}
</style>
