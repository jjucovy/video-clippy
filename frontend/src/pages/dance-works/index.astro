---
export const prerender = false;
import Layout from '@/layouts/Layout.astro';
import { list } from '@/lib/api';

// Get filter from URL
const url = new URL(Astro.request.url);
const genreFilter = url.searchParams.get('genre');

// Fetch genres for filter buttons
const customFields = await list('custom-fields');
const genreField = customFields.find((f: any) => f.name === 'Genre');
const genres: string[] = genreField?.choices || [];

// Fetch dance works, optionally filtered by genre
let pieces;
if (genreFilter) {
	pieces = await list(`pieces?custom_Genre=${encodeURIComponent(genreFilter)}`);
} else {
	pieces = await list('pieces');
}
---

<Layout title="Dance Works">
	<h1>Dance Works</h1>

	{genres.length > 0 && (
		<div class="filters">
			<span class="filter-label">Filter by genre:</span>
			<a
				href="/dance-works"
				class:list={["filter-btn", { active: !genreFilter }]}
			>
				All
			</a>
			{genres.map((genre) => (
				<a
					href={`/dance-works?genre=${encodeURIComponent(genre)}`}
					class:list={["filter-btn", { active: genreFilter === genre }]}
				>
					{genre}
				</a>
			))}
		</div>
	)}

	{pieces.length > 0 ? (
		<ul class="pieces-list">
			{pieces.map((piece: any) => (
				<li>
					<a href={`/dance-works/${piece.id}`} class="piece-card">
						<span class="piece-title">{piece.title}</span>
						{piece.choreographers?.length > 0 && (
							<span class="choreographer">by {piece.choreographers.map((c: any) => c.name).join(' & ')}</span>
						)}
						{piece.custom_fields?.Genre && (
							<span class="genre-tag">{piece.custom_fields.Genre.value}</span>
						)}
					</a>
				</li>
			))}
		</ul>
	) : (
		<p class="no-items">No dance works found{genreFilter ? ` in genre "${genreFilter}"` : ''}.</p>
	)}
</Layout>

<style>
	h1 {
		text-align: center;
		margin-bottom: var(--spacing-lg);
	}

	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-sm);
		align-items: center;
		justify-content: center;
		margin-bottom: var(--spacing-xl);
		padding: var(--spacing-md);
		background: var(--color-white);
		border-radius: var(--border-radius);
		box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
	}

	.filter-label {
		font-size: 0.875rem;
		color: var(--color-text-light);
		margin-right: var(--spacing-sm);
	}

	.filter-btn {
		display: inline-block;
		padding: 0.375rem 0.75rem;
		background: var(--color-light-gray);
		color: var(--color-text);
		text-decoration: none;
		border-radius: 1rem;
		font-size: 0.875rem;
		font-weight: 500;
		transition: var(--transition);
	}

	.filter-btn:hover {
		background: var(--color-secondary);
		color: var(--color-white);
	}

	.filter-btn.active {
		background: var(--color-secondary);
		color: var(--color-white);
	}

	.pieces-list {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: var(--spacing-md);
	}

	.piece-card {
		display: block;
		padding: var(--spacing-lg);
		background: var(--color-white);
		border-radius: var(--border-radius);
		box-shadow: 0 2px 15px rgba(0, 0, 0, 0.1);
		text-decoration: none;
		transition: var(--transition);
	}

	.piece-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
	}

	.piece-title {
		display: block;
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--color-dark);
		margin-bottom: var(--spacing-xs);
	}

	.choreographer {
		display: block;
		font-size: 0.875rem;
		color: var(--color-text-light);
		font-style: italic;
		margin-bottom: var(--spacing-sm);
	}

	.genre-tag {
		display: inline-block;
		padding: 0.125rem 0.5rem;
		background: var(--color-light-gray);
		color: var(--color-secondary);
		border-radius: 0.75rem;
		font-size: 0.75rem;
		font-weight: 500;
	}

	.no-items {
		text-align: center;
		color: var(--color-text-light);
		font-style: italic;
	}
</style>
