---
export const prerender = false;
import Layout from '@/layouts/Layout.astro';
import { list } from '@/lib/api';

const url = new URL(Astro.request.url);
const genreFilter = url.searchParams.get('genre');

const customFields = await list('custom-fields');
const genreField = customFields.find((f: any) => f.name === 'Genre');
const genres: string[] = genreField?.choices || [];

let pieces: any[];
if (genreFilter) {
	pieces = await list(`pieces?custom_Genre=${encodeURIComponent(genreFilter)}`);
} else {
	pieces = await list('pieces');
}

pieces = pieces.sort((a: any, b: any) => a.title.localeCompare(b.title));
---

<Layout title="Dance Works">
	<div class="page-header">
		<span class="section-eyebrow">Repertoire</span>
		<h1>Dance Works</h1>
		<p class="page-subtitle">Choreographic works rooted in Isadora Duncan's legacy</p>
	</div>

	{genres.length > 0 && (
		<div class="filters">
			<span class="filter-label">Genre</span>
			<a href="/dance-works" class:list={["filter-btn", { active: !genreFilter }]}>All</a>
			{genres.map((genre) => (
				<a href={`/dance-works?genre=${encodeURIComponent(genre)}`}
				   class:list={["filter-btn", { active: genreFilter === genre }]}>
					{genre}
				</a>
			))}
		</div>
	)}

	{pieces.length === 0 ? (
		<div class="empty-state">
			<p>No dance works found{genreFilter ? ` in "${genreFilter}"` : ''}.</p>
		</div>
	) : (
		<div class="works-grid">
			{pieces.map((piece: any) => {
				const genre = piece.custom_fields?.Genre?.value;
				const choreographers = piece.choreographers?.map((c: any) => c.name) || [];
				return (
					<a href={`/dance-works/${piece.id}`} class="work-card">
						<div class="work-accent"></div>
						<div class="work-body">
							<h3 class="work-title">{piece.title}</h3>
							{choreographers.length > 0 && (
								<p class="work-choreographer">
									<span class="by-label">by</span> {choreographers.join(' & ')}
								</p>
							)}
						</div>
						<div class="work-footer">
							{genre
								? <span class="work-genre">{genre}</span>
								: <span class="work-genre work-genre--empty">&mdash;</span>
							}
							<span class="work-arrow">↗</span>
						</div>
					</a>
				);
			})}
		</div>
	)}
</Layout>

<style>
.works-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
	gap: var(--spacing-md);
}

.work-card {
	display: flex;
	flex-direction: column;
	background: var(--color-bg-card);
	border-radius: var(--button-radius);
	overflow: hidden;
	box-shadow: var(--shadow-card);
	border: 1px solid var(--color-light-gray);
	text-decoration: none;
	color: inherit;
	transition: var(--transition);
	position: relative;
}

.work-card:hover {
	transform: translateY(-3px);
	box-shadow: var(--shadow-card-hover);
	border-color: var(--color-primary);
}

/* Primary accent bar at top */
.work-accent {
	height: 4px;
	background: var(--color-primary);
	transition: height 0.18s ease;
}

.work-card:hover .work-accent {
	height: 5px;
	background: var(--color-secondary);
}

.work-body {
	flex: 1;
	padding: var(--spacing-md) var(--spacing-md) var(--spacing-sm);
}

.work-title {
	font-size: 1.05rem;
	color: var(--color-dark);
	margin: 0 0 0.5rem;
	line-height: 1.3;
	text-align: left;
}

.work-card:hover .work-title {
	color: var(--color-secondary);
}

.work-choreographer {
	font-size: 0.8rem;
	color: var(--color-text-muted);
	margin: 0;
	font-weight: 400;
}

.by-label {
	font-style: italic;
	margin-right: 0.2em;
}

.work-footer {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: var(--spacing-sm) var(--spacing-md);
	border-top: 1px solid var(--color-light-gray);
}

.work-genre {
	font-size: 0.68rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.12em;
	color: var(--color-primary);
}

.work-genre--empty {
	color: var(--color-text-muted);
	font-weight: 400;
}

.work-arrow {
	font-size: 1rem;
	color: var(--color-text-muted);
	transition: transform 0.22s ease, color 0.22s ease;
	opacity: 0.5;
}

.work-card:hover .work-arrow {
	transform: translate(2px, -2px);
	color: var(--color-secondary);
	opacity: 1;
}

@media (max-width: 640px) {
	.works-grid { grid-template-columns: 1fr; }
}
</style>
