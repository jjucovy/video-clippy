---
export const prerender = false;
import Layout from '@/layouts/Layout.astro';
import { list } from '@/lib/api';

// Fetch the Genre custom field to get the list of genre choices
const customFields = await list('custom-fields');
const genreField = customFields.find((f: any) => f.name === 'Genre');
const genres: string[] = genreField?.choices || [];
---

<Layout title="Genres">
	<h1>Browse by Genre</h1>

	{genres.length > 0 ? (
		<ul class="genre-list">
			{genres.map((genre) => (
				<li>
					<a href={`/genres/${encodeURIComponent(genre)}`} class="genre-card">
						<span class="genre-name">{genre}</span>
					</a>
				</li>
			))}
		</ul>
	) : (
		<p class="no-genres">No genres have been configured yet.</p>
	)}
</Layout>

<style>
	h1 {
		text-align: center;
		margin-bottom: var(--spacing-xl);
	}

	.genre-list {
		list-style: none;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: var(--spacing-lg);
		max-width: 800px;
		margin: 0 auto;
	}

	.genre-card {
		display: block;
		padding: var(--spacing-xl) var(--spacing-lg);
		background: var(--color-white);
		border-radius: var(--border-radius);
		box-shadow: 0 2px 15px rgba(0, 0, 0, 0.1);
		text-decoration: none;
		text-align: center;
		transition: var(--transition);
	}

	.genre-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
	}

	.genre-name {
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-dark);
		font-family: var(--font-heading);
	}

	.no-genres {
		text-align: center;
		color: var(--color-text-light);
		font-style: italic;
	}
</style>
